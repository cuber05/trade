# CryptoTerminal — Environment Configuration
# Copy this file to .env and fill in your values

# ═══════════════════════════════════════════════
# API KEYS
# ═══════════════════════════════════════════════

# CoinGecko (free tier works without key, rate-limited to ~10-30 calls/min)
# Get a free key at: https://www.coingecko.com/en/api
COINGECKO_API_KEY=

# Groq (for AI analysis — falls back to built-in engine if not set)
# Get key at: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama3-8b-8192

# Reddit (for sentiment analysis)
# Create app at: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=CryptoTerminal/1.0

# ═══════════════════════════════════════════════
# SERVER
# ═══════════════════════════════════════════════
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ═══════════════════════════════════════════════
# CACHE TTL (seconds)
# ═══════════════════════════════════════════════
CACHE_TTL_MARKET=60
CACHE_TTL_COIN=30
CACHE_TTL_CHART=120
CACHE_TTL_NEWS=300
CACHE_TTL_FEAR_GREED=600
CACHE_TTL_DEX=60
CACHE_TTL_DEFI=120
CACHE_TTL_REDDIT=300
